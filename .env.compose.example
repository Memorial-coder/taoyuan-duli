# 宿主机暴露端口，可按需改成 80 / 443 后面的反向代理入口
HOST_PORT=4014

# 会话密钥：至少 24 位随机长字符串，不能直接照抄示例值
SECRET_KEY=请替换成至少24位随机长字符串

# 普通管理员口令：至少 12 位，不能直接照抄示例值
ADMIN_TOKEN=请替换成至少12位管理员口令

# 超级管理员口令：可留空；如填写，不能与 ADMIN_TOKEN 相同
SUPER_ADMIN_TOKEN=请替换成至少12位超级管理员口令

# 生产环境建议填写你的 HTTPS 域名；如果走同域反代，也可以按实际情况调整
CORS_ALLOWED_ORIGINS=https://你的域名

# 若部署在 HTTPS 反向代理后，建议开启
COOKIE_SECURE=true

# 默认使用本地文件用户库；若你准备接 MySQL，请继续填写下面几项
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=taoyuan
# MYSQL_PASSWORD=请填写你的数据库密码
# MYSQL_DATABASE=taoyuan

# 可选业务参数
DEFAULT_USER_QUOTA=2000000
EXCHANGE_RATE=500000
TAOYUAN_EXCHANGE_RATE_DOLLAR_PER_MONEY=0.0002
