# 本地统一运行端口（前端静态页与 /api 都走这个端口）
PORT=4013

# 会话密钥（请改成一段随机长字符串，示例值会在启动时被拒绝）
SECRET_KEY=请填写随机会话密钥

# 普通管理员口令（进入 /admin 与 /admin/users 时填写这个，请务必修改；示例值会在启动时被拒绝）
ADMIN_TOKEN=请填写普通管理员口令

# 超级管理员口令（留空则 ADMIN_TOKEN 直接视为超级管理员；如配置，不能与 ADMIN_TOKEN 相同）
SUPER_ADMIN_TOKEN=请填写超级管理员口令

# 允许跨域携带 Cookie 的来源列表（逗号分隔）
# 本地 4013 / 4014 联调可直接使用下面这行
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4013,http://localhost:4013,http://127.0.0.1:4014,http://localhost:4014

# 如部署在 HTTPS 反向代理后，并希望 Cookie 只走 HTTPS，可改为 true
COOKIE_SECURE=false

# 本地存储文件位置
DB_STORAGE=d:/taoyuan - 副本/taoyuan-duli/data/.storage.json

# MySQL 连接配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=taoyuan

# 这里填“数据库密码”，不是玩家登录密码
MYSQL_PASSWORD=请填写你的数据库密码
MYSQL_DATABASE=taoyuan

# 新注册用户默认额度
DEFAULT_USER_QUOTA=2000000
EXCHANGE_RATE=500000
TAOYUAN_EXCHANGE_RATE_DOLLAR_PER_MONEY=0.0002
