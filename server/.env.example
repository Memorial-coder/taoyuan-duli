# Local unified service port
PORT=4013

# Session secret; replace with a random long string before startup
SECRET_KEY=replace_with_a_random_session_secret

# Admin password for /admin and /admin/users
ADMIN_TOKEN=replace_with_admin_token

# Optional super admin password; if empty, ADMIN_TOKEN is treated as super admin
SUPER_ADMIN_TOKEN=replace_with_super_admin_token

# Comma-separated allowed origins that may send cookies in cross-origin requests
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4013,http://localhost:4013,http://127.0.0.1:4014,http://localhost:4014

# Set to true when serving behind HTTPS reverse proxy
COOKIE_SECURE=false

# Local storage path
DB_STORAGE=d:/taoyuan-latest/taoyuan-duli/data/.storage.json

# MySQL connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=taoyuan
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DATABASE=taoyuan

# User defaults
DEFAULT_USER_QUOTA=2000000
EXCHANGE_RATE=500000
TAOYUAN_EXCHANGE_RATE_DOLLAR_PER_MONEY=0.0002
